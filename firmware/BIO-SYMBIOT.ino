  u8g2.drawLine(88, 36, 104, 36);
  if ((millis() / 250) % 2 == 0) {
    u8g2.drawPixel(75, 45); u8g2.drawPixel(115, 45);
  } else {
    u8g2.drawPixel(73, 50); u8g2.drawPixel(117, 50);
  }
}


void drawManualFace() {
  u8g2.drawCircle(96, 36, 16, U8G2_DRAW_ALL);
  u8g2.drawBox(82, 26, 13, 6); u8g2.drawBox(97, 26, 13, 6);
  u8g2.drawLine(95, 28, 97, 28);
  u8g2.drawCircle(96, 42, 4, U8G2_DRAW_LOWER_LEFT | U8G2_DRAW_LOWER_RIGHT);
}


void drawFaceForState() {
  switch(currentState) {
    case STATE_HEALTHY: drawJoyousFace(); break;
    case STATE_SOIL_BAD: drawThirstyFace(); break;
    case STATE_LIGHT_BAD: drawSleepingFace(); break;
    case STATE_CRITICAL: drawFearFace(); break;
    case STATE_RECOVERING: drawNeutralFace(); break;
    case STATE_WATERING: drawWateringFace(); break;
    case STATE_MANUAL_MODE: drawManualFace(); break;
    case STATE_LIGHT_TOO_HIGH: drawFearFace(); break;
    case STATE_SOIL_TOO_HIGH: drawThirstyFace(); break;
    case STATE_BOTH_TOO_HIGH: drawFearFace(); break;
    default: drawNeutralFace(); break;
  }
}


BLYNK_WRITE(V1) {
  if (param.asInt() == 1) {
    currentState = STATE_HEALTHY; previousState = STATE_HEALTHY;
    splashActive = false; backupAutoPumpActive = false;
    dryAlertTriggered = false; manualPumpOverride = false;
    waitingForRecheck = false; bootWeatherOverlayActive = false;
    currentDisplayMode = 0;
    digitalWrite(PUMP_PIN, PUMP_OFF); Blynk.virtualWrite(V7, 0);
    u8g2.begin();
  }
}


BLYNK_WRITE(V7) {
  int switchState = param.asInt();
  if (switchState == 1) {
    manualPumpOverride = true; backupAutoPumpActive = false; waitingForRecheck = false;
    digitalWrite(PUMP_PIN, PUMP_ON); showSplashMessage("MANUAL OVERRIDE");
  } else {
    manualPumpOverride = false; digitalWrite(PUMP_PIN, PUMP_OFF);
  }
}


BLYNK_WRITE(V8) {
  currentDisplayMode = param.asInt();
}


void handleTouchInput() {
  static int lastTouchState = LOW;
  int currentTouch = digitalRead(TOUCH_PIN);


  if (currentTouch == HIGH && lastTouchState == LOW) {  // Rising edge = new tap
    unsigned long now = millis();


    if ((now - lastTouchTime) < doubleTapWindow) {
      
      touchCount = 2;
      Serial.println("Double Tap Detected!");
      if (currentDisplayMode == 0) {
        currentDisplayMode = 2;
      } else {
        currentDisplayMode = 0;
      }
    } else {
      touchCount = 1;
      Serial.println("Single Tap Registered (waiting for possible double)");
    }
    
    lastTouchTime = now;
  }


  lastTouchState = currentTouch;


  static unsigned long singleTapCheckTime = 0;
  if (touchCount == 1 && millis() - lastTouchTime > doubleTapWindow) {
    Serial.println("Single Tap Confirmed → Limbic Toggle");
    
    if (currentDisplayMode == 0) {
      currentDisplayMode = 1;
    } else if (currentDisplayMode == 1) {
      currentDisplayMode = 0;
    } else {
      currentDisplayMode = 1;
    }
    
    touchCount = 0;
  }
}
void runInteractiveStateCore() {
  ESP.wdtFeed();
  float lux = lightMeter.readLightLevel();
  if (isnan(lux) || lux < 0) lux = 0;
  int rawMoisture = analogRead(MOISTURE_PIN);
  isAirHealthy = (digitalRead(AQI_PIN) == HIGH);
  lightPercentage = constrain(map((int)lux, 0, (int)MAX_EXPECTED_LUX, 0, 100), 0, 100);
  const int SENSOR_DRY = 1024;
  const int SENSOR_WATER = 400;
  moisturePercentage = constrain(map(rawMoisture, SENSOR_DRY, SENSOR_WATER, 0, 100), 0, 100);
  if(rawMoisture <= 430) moisturePercentage = 100;


  bool isDark = (lux < DEEP_DARK_THRESHOLD);
  bool isDry = (rawMoisture > DRY_SOIL_THRESHOLD);
  bool isLightHealthy = (lightPercentage >= 30 && lightPercentage < 100);
  bool isMoistureHealthy = (rawMoisture <= WET_SOIL_THRESHOLD && rawMoisture >= FLOODED_SOIL_THRESHOLD);
  bool isLightTooHigh = (lux >= TOO_HIGH_LIGHT_THRESHOLD);
  bool isMoistureTooHigh = (rawMoisture < FLOODED_SOIL_THRESHOLD);


  if (manualPumpOverride) {
    digitalWrite(PUMP_PIN, PUMP_ON); dryAlertTriggered = false; backupAutoPumpActive = false; waitingForRecheck = false;
  } else {
    if (waitingForRecheck) {
      digitalWrite(PUMP_PIN, PUMP_OFF);
      if (millis() - recheckStartTimestamp >= 300000) {
        waitingForRecheck = false;
        if (analogRead(MOISTURE_PIN) > DRY_SOIL_THRESHOLD) {
          backupAutoPumpActive = true; autoPumpStartTimestamp = millis();
          digitalWrite(PUMP_PIN, PUMP_ON); showSplashMessage("RE-CHECK: AUTO ON");
        } else {
          dryAlertTriggered = false; showSplashMessage("SOIL RECOVERED");
        }
      }
    }
    else if (backupAutoPumpActive) {
      digitalWrite(PUMP_PIN, PUMP_ON);
      if (millis() - autoPumpStartTimestamp >= 30000) {
        digitalWrite(PUMP_PIN, PUMP_OFF); backupAutoPumpActive = false;
        waitingForRecheck = true; recheckStartTimestamp = millis();
        showSplashMessage("AUTO OFF: WAITING");
      }
    }
    else {
      if (isDry) {
        if (!dryAlertTriggered) {
          drySoilTimestamp = millis(); dryAlertTriggered = true;
          showSplashMessage("TURN ON PUMP!");
        } else {
          if (millis() - drySoilTimestamp >= 60000) {
            backupAutoPumpActive = true; autoPumpStartTimestamp = millis();
            digitalWrite(PUMP_PIN, PUMP_ON); showSplashMessage("TIMEOUT: AUTO ON");
          }
        }
      } else {
        dryAlertTriggered = false;
      }
    }
  }


  previousState = currentState;
  if (manualPumpOverride) currentState = STATE_MANUAL_MODE;
  else if (backupAutoPumpActive) currentState = STATE_WATERING;
  else if (isLightTooHigh && isMoistureTooHigh) currentState = STATE_BOTH_TOO_HIGH;
  else if (isLightTooHigh) currentState = STATE_LIGHT_TOO_HIGH;
  else if (isMoistureTooHigh) currentState = STATE_SOIL_TOO_HIGH;
  else if (isDark && isDry) currentState = STATE_CRITICAL;
  else if (isDark) currentState = STATE_LIGHT_BAD;
  else if (isDry) currentState = STATE_SOIL_BAD;
  else if (isLightHealthy && isMoistureHealthy) currentState = STATE_HEALTHY;
  else currentState = STATE_RECOVERING;


  if (currentState != previousState) {
    showStateMessage(currentState);
    handleStateNotifications(currentState, previousState);
  }


  if (Blynk.connected()) {
    Blynk.virtualWrite(V0, lux);
    Blynk.virtualWrite(V2, lightPercentage); Blynk.virtualWrite(V3, rawMoisture);
    Blynk.virtualWrite(V4, moisturePercentage); Blynk.virtualWrite(V5, lux);
  }


  int runningScore = 100;
  if (!isMoistureHealthy) runningScore -= 25;
  if (!isLightHealthy) runningScore -= 15;
  if (!isAirHealthy) runningScore -= 20;
  int internalTemp = localWeatherTemp.toInt();
  if (internalTemp > 38 || internalTemp < 12) runningScore -= 15;
  globalLimbicIndex = constrain(runningScore, 15, 100);
  globalHeartRate = map(globalLimbicIndex, 100, 15, 66, 138);
  static int moistureAvg = 50;
  static int lightAvg = 50;
  static bool firstTelemetry = true;
  
  if (firstTelemetry) {
    moistureAvg = moisturePercentage;
    lightAvg = lightPercentage;
    firstTelemetry = false;
  } else {
    moistureAvg = 0.65 * moistureAvg + 0.35 * moisturePercentage;
    lightAvg = 0.65 * lightAvg + 0.35 * lightPercentage;
  }


  moistureAvg = constrain(moistureAvg, 0, 100);
  lightAvg = constrain(lightAvg, 0, 100);


  Serial.print("Moisture_Percent:"); Serial.print(moistureAvg);
  Serial.print(" Light_Percent:");   Serial.print(lightAvg);
  Serial.print(" State_Index:");     Serial.println(currentState);
  Serial.print(" Raw_D6_Read:");     Serial.println(digitalRead(AQI_PIN));
}


void refreshSystemDisplay() {
  if (bootWeatherOverlayActive) {
    if (millis() - bootWeatherOverlayStart < 15000) {
      drawDedicatedWeatherScreen();
      return;
    } else {
      bootWeatherOverlayActive = false;
    }
  }
  if (splashActive) {
    drawSplashScreen();
    if (millis() - splashStartTime > 2000) splashActive = false;
    return;
  }


  u8g2.clearBuffer();
  if (currentDisplayMode == 1) {
    u8g2.drawFrame(0, 0, 128, 64);
    drawHumanLimbicDashboard(globalLimbicIndex, globalHeartRate);
  } else if (currentDisplayMode == 2) {
    drawDedicatedWeatherScreen();
  } else {
    drawVisualProgressBar(0, 9, 48, 8, lightPercentage, "LIGHT");
    drawVisualProgressBar(0, 27, 48, 8, moisturePercentage, "SOIL");
    u8g2.setFont(u8g2_font_5x7_tf);
    u8g2.setCursor(0, 44);
    u8g2.print("WTH: ");
    u8g2.print(localWeatherTemp);
    u8g2.print("\xb0");
    u8g2.print("C");
    u8g2.setCursor(0, 52);
    u8g2.print(localWeatherDesc.substring(0, 14));
    u8g2.setCursor(0, 62);
    u8g2.print("AIR: "); u8g2.print(isAirHealthy ? "GD " : "PR ");
    u8g2.print(Blynk.connected() ? (manualPumpOverride ? "| MAN" : "| ONL") : "| OFL");
    drawFaceForState();
  }
  u8g2.sendBuffer();
}


void setup() {
  Serial.begin(115200);
  delay(500);
  pinMode(MOISTURE_PIN, INPUT);
  pinMode(PUMP_PIN, OUTPUT);
  pinMode(AQI_PIN, INPUT);
  pinMode(TOUCH_PIN, INPUT);
  digitalWrite(PUMP_PIN, PUMP_OFF);
  Wire.begin(D2, D1);
  lightMeter.begin(BH1750::CONTINUOUS_HIGH_RES_MODE);
  u8g2.begin();
  WiFi.begin(ssid, pass);
  int connectTimeout = 0;
  while (WiFi.status() != WL_CONNECTED && connectTimeout < 20) { delay(500); connectTimeout++; }
  fetchGoogleWeatherMetrics();
  lastWeatherUpdate = millis();
  runCuriousBootAnimation();
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  timer.setInterval(1000L, runInteractiveStateCore);
}
void loop() {
  if (WiFi.status() != WL_CONNECTED) WiFi.begin(ssid, pass);
  Blynk.run();
  timer.run();


  if (millis() - lastWeatherUpdate >= weatherInterval) {
    fetchGoogleWeatherMetrics();
    lastWeatherUpdate = millis();
  }


  handleTouchInput();


  static unsigned long lastDisplay = 0;
  if (millis() - lastDisplay >= 33) {
    refreshSystemDisplay();
    lastDisplay = millis();
  }
}
