void sendEvent(const char* eventName, const String &message) {
  for (int i = 0; i < NUM_EVENT_CODES; i++) {
    if (strcmp(eventCooldowns[i].code, eventName) == 0) {
      if (millis() - eventCooldowns[i].lastSent > notificationCooldown || eventCooldowns[i].lastSent == 0) {
        if (Blynk.connected()) {
          Blynk.logEvent(eventName, message);
          eventCooldowns[i].lastSent = millis();
          Serial.print("Blynk event sent: ");
          Serial.println(eventName);
        }
      }
      return;
    }
  }
  
  if (Blynk.connected()) {
    Blynk.logEvent(eventName, message);
  }
}


void handleStateNotifications(SystemState newState, SystemState oldState) {
  switch (newState) {
    case STATE_LIGHT_BAD:
      sendEvent("light_alert", "Plant status: Dramatic wilting risk - light too low");
      break;
    case STATE_SOIL_BAD:
      sendEvent("soil_alert", "Plant status: Dramatic wilting risk - soil too dry");
      break;
    case STATE_CRITICAL:
      sendEvent("light_soil_critical", "Plant status: Dramatic wilting risk - critical (dark + dry)");
      break;
    default:
      break;
  }


  bool wasLightBad = (oldState == STATE_LIGHT_BAD || oldState == STATE_CRITICAL);
  bool isLightBadNow = (newState == STATE_LIGHT_BAD || newState == STATE_CRITICAL);
  if (wasLightBad && !isLightBadNow) {
    sendEvent("light_restored", "Light conditions returned to normal");
  }


  bool wasSoilBad = (oldState == STATE_SOIL_BAD || oldState == STATE_CRITICAL);
  bool isSoilBadNow = (newState == STATE_SOIL_BAD || newState == STATE_CRITICAL);
  if (wasSoilBad && !isSoilBadNow) {
    sendEvent("soil_restored", "Soil moisture returned to healthy range");
  }
}


