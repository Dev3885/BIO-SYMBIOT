    case STATE_SOIL_BAD: showSplashMessage("SOIL IS DRY"); break;
    case STATE_LIGHT_BAD: showSplashMessage("TOO DARK"); break;
    case STATE_CRITICAL: showSplashMessage("CRITICAL CONDITION"); break;
    case STATE_WATERING: showSplashMessage("WATERING ACTIVE"); break;
    case STATE_MANUAL_MODE: showSplashMessage("MANUAL OVERRIDE"); break;
    case STATE_LIGHT_TOO_HIGH: showSplashMessage("SCORCHING LIGHT"); break;
