void drawWeatherIconGraphic(int x, int y, String condition) {
  condition.toLowerCase();
  if (condition.indexOf("sun") != -1 || condition.indexOf("clear") != -1) {
    u8g2.drawCircle(x + 10, y + 10, 6);
    for (int i = 0; i < 360; i += 45) {
      float rad = i * 0.0174532925;
      int x1 = (x + 10) + cos(rad) * 8; int y1 = (y + 10) + sin(rad) * 8;
      int x2 = (x + 10) + cos(rad) * 11; int y2 = (y + 10) + sin(rad) * 11;
      u8g2.drawLine(x1, y1, x2, y2);
    }
  } else if (condition.indexOf("rain") != -1 || condition.indexOf("shower") != -1) {
    u8g2.drawDisc(x + 6, y + 10, 5); u8g2.drawDisc(x + 11, y + 7, 6); u8g2.drawDisc(x + 16, y + 10, 4);
    u8g2.drawBox(x + 6, y + 11, 11, 4);
    u8g2.drawLine(x + 6, y + 17, x + 4, y + 21); u8g2.drawLine(x + 11, y + 17, x + 9, y + 21); u8g2.drawLine(x + 16, y + 17, x + 14, y + 21);
  } else {
    u8g2.drawDisc(x + 5, y + 11, 5); u8g2.drawDisc(x + 10, y + 7, 6); u8g2.drawDisc(x + 16, y + 10, 5);
    u8g2.drawBox(x + 5, y + 11, 12, 5);
  }
}


