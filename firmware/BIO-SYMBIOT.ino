void fetchGoogleWeatherMetrics() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClient client;
    HTTPClient http;
    if (http.begin(client, "http://wttr.in/?format=%t|%C|%f")) {
      int httpCode = http.GET();
      if (httpCode == HTTP_CODE_OK) {
        String payload = http.getString();
        payload.trim();
        int firstPipe = payload.indexOf('|');
        int secondPipe = payload.indexOf('|', firstPipe + 1);
        if (firstPipe != -1 && secondPipe != -1) {
          localWeatherTemp = payload.substring(0, firstPipe);
          localWeatherDesc = payload.substring(firstPipe + 1, secondPipe);
          tomorrowForecast = payload.substring(secondPipe + 1);
          localWeatherTemp.replace("Â", "");
          localWeatherTemp.replace("°", "");
          localWeatherTemp.replace("C", "");
          localWeatherTemp.trim();
          tomorrowForecast.replace("Â", "");
          tomorrowForecast.replace("°", "");
          tomorrowForecast.replace("C", "");
          tomorrowForecast.trim();
        }
      }
      http.end();
    }
  }
}


