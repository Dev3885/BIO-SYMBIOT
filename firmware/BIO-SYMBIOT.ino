void drawClinicalECG(int xStart, int xEnd, int yCenter, int bpm) {
  int prevX = xStart;
  int prevY = yCenter;
  float speedFactor = (float)bpm / 60.0;
  unsigned long t = millis();
  for (int x = xStart; x <= xEnd; x++) {
    float phase = (x - xStart - (t * 0.04 * speedFactor));
    int p = (int)phase % 30;
    if (p < 0) p += 30;
    int yOffset = 0;
    if (p >= 2 && p <= 5) yOffset = -sin((p - 2) * 3.14159 / 3.0) * 3;
    else if (p == 7) yOffset = 2;
    else if (p == 8) yOffset = -16;
    else if (p == 9) yOffset = 5;
    else if (p >= 12 && p <= 17) yOffset = -sin((p - 12) * 3.14159 / 5.0) * 4;
    int currentY = yCenter + yOffset;
    if (x > xStart) u8g2.drawLine(prevX, prevY, x, currentY);
    prevX = x;
    prevY = currentY;
  }
}


